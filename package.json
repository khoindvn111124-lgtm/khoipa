{
  "name": "ipa-downloader",
  "version": "1.0.0",
  "description": "Website to download IPA files from repositories",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node merge-repos.js && node -e \"var fs=require('fs');['app.js','index.html','khoipa.txt'].forEach(function(f){fs.copyFileSync(f,'dist/'+f)})\""
  },
  "dependencies": {

    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  }
}
